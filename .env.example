NODE_ENV=development

# Runtime connection: NOBYPASSRLS, enforced by FORCE ROW LEVEL SECURITY.
# Requests must set `app.current_tenant_id` per transaction (done automatically
# by PrismaService when TenantContext is populated by tenant.middleware).
DATABASE_URL=postgresql://domera_app:domera_app@localhost:5432/domera_local?schema=public

# Migration connection: BYPASSRLS. Used by `prisma migrate deploy`, the raw-SQL
# migration runner (`pnpm --filter @domera/api db:migrate:sql`), the RLS applier
# (`pnpm --filter @domera/api db:rls`), and seed scripts. See
# docs/architecture/database-migrations.md for the full workflow.
DATABASE_URL_MIGRATOR=postgresql://domera_migrator:domera_migrator@localhost:5432/domera_local?schema=public

# Superuser connection: only needed when (re)running 002_split_roles.sql to
# provision roles + transfer ownership. Omit in production.
DATABASE_URL_SUPER=postgresql://domera_admin:domera_admin@localhost:5432/domera_local?schema=public

REDIS_URL=redis://localhost:6379

APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_TENANT_ID=ten_demo
NEXT_PUBLIC_DEMO_WORKSPACE_SLUG=northstone-demo
NEXT_PUBLIC_DEMO_BUILDING_SLUG=nt01

ALLOW_DEMO_SEED=false
ALLOW_NONLOCAL_DEMO_SEED=false
DEMO_SEED_NAME=test-building
DEMO_SEED_VERSION=2026-04-18
DEMO_WORKSPACE_SLUG=northstone-demo
DEMO_BUILDING_SLUG=nt01
DEMO_DISABLE_EMAIL=true
DEMO_DISABLE_SMS=true
DEMO_DISABLE_WEBHOOKS=true
DEMO_STORAGE_PREFIX=demo/northstone-demo
DEMO_ONLY_RESERVED_DOMAINS=true

AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
