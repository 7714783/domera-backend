NODE_ENV=development

DATABASE_URL=postgresql://domera_app:domera_app@localhost:5432/domera_local?schema=public
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-in-production
PORT=4000

# Demo / seed guards (set ALLOW_DEMO_SEED=true before running seed-test-building)
ALLOW_DEMO_SEED=false
ALLOW_NONLOCAL_DEMO_SEED=false
DEMO_SEED_NAME=test-building
DEMO_SEED_VERSION=2026-04-18
DEMO_DISABLE_EMAIL=true
DEMO_DISABLE_SMS=true
DEMO_DISABLE_WEBHOOKS=true
DEMO_STORAGE_PREFIX=demo/northstone-demo
DEMO_ONLY_RESERVED_DOMAINS=true

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
