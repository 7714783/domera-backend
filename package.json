{
  "name": "@domera/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:worker": "node prisma/seeds/register-schedulers.mjs",
    "seed:test-building": "node prisma/seeds/seed-test-building.mjs",
    "seed": "pnpm run seed:test-building",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:resolve": "prisma migrate resolve",
    "db:migrate:reset": "prisma migrate reset",
    "db:migrate:sql": "node prisma/migrations-sql/apply-migrations.mjs",
    "db:rls": "node prisma/rls/apply-rls.mjs 002_split_roles.sql 001_enable_rls.sql 003_force_rls.sql 004_public_qr_rpc.sql",
    "db:deploy": "pnpm run db:migrate:deploy && pnpm run db:migrate:sql && pnpm run db:rls",
    "db:push:sandbox": "prisma db push",
    "postinstall": "prisma generate",
    "lint": "echo \"todo: lint api\"",
    "test": "node test/auth-smoke.mjs",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "node prisma/seeds/seed-test-building.mjs"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^6.16.3",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.58.0",
    "jsonwebtoken": "^9.0.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rrule": "^2.8.1",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.17",
    "prisma": "^6.16.3",
    "typescript": "^5.8.3"
  }
}
