generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Compliance profiles (P5): per-jurisdiction / per-building rule bundles ──
model ComplianceProfile {
  id           String   @id @default(uuid())
  tenantId     String
  key          String   // "IL-SI1525", "ASHRAE180", "NFPA25", custom
  name         String
  jurisdiction String?  // ISO country code or "global"
  description  String?
  domains      String[] @default([])
  obligationTemplateIds String[] @default([])
  isActive     Boolean  @default(true)
  isBuiltIn    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments BuildingComplianceProfile[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("compliance_profiles")
}

model BuildingComplianceProfile {
  id         String   @id @default(uuid())
  tenantId   String
  buildingId String
  profileId  String
  assignedAt DateTime @default(now())
  assignedBy String?

  profile ComplianceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([buildingId, profileId])
  @@index([tenantId, buildingId])
  @@map("building_compliance_profiles")
}

model Tenant {
  id                   String                 @id @default(uuid())
  slug                 String                 @unique
  name                 String
  status               String                 @default("active")
  storageMode          String                 @default("pooled")
  defaultUiLocale      String                 @default("en")
  defaultContentLocale String                 @default("en")
  timezone             String                 @default("UTC")
  isDemo               Boolean                @default(false)
  seedKey              String?                @unique
  createdBy            String?                @default("system")
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  memberships          Membership[]
  buildings            Building[]
  organizations        Organization[]
  obligations          ObligationTemplate[]
  buildingObligations  BuildingObligation[]
  ppmTemplates         PpmTemplate[]
  ppmPlanItems         PpmPlanItem[]
  tasks                TaskInstance[]
  budgets              Budget[]
  invoices             Invoice[]
  approvals            ApprovalRequest[]
  documents            Document[]
  audits               AuditEntry[]
  assets               Asset[]
  seedRuns             SeedRun[]
  approvalPolicies     ApprovalPolicy[]
  approvalDelegations  ApprovalDelegation[]

  @@map("tenants")
}

model User {
  id                      String                 @id @default(uuid())
  email                   String
  emailNormalized         String                 @unique
  username                String?                @unique
  passwordHash            String?
  displayName             String?
  status                  String                 @default("active")
  isSuperAdmin            Boolean                @default(false)
  lastLoginAt             DateTime?
  isDemo                  Boolean                @default(false)
  seedKey                 String?                @unique
  createdBy               String?                @default("system")
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  memberships             Membership[]
  organizationMemberships OrganizationMembership[]
  buildingRoles           BuildingRoleAssignment[]
  certifications          UserCertification[]
  sessions                Session[]

  @@map("users")
}

model Session {
  id          String    @id @default(uuid())
  userId      String
  tokenHash   String    @unique
  createdAt   DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?
  revokedBy   String?
  userAgent   String?
  ipAddress   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Membership {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  roleKey   String
  status    String   @default("active")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, roleKey])
  @@index([tenantId, userId])
  @@map("memberships")
}

model Organization {
  id          String                 @id @default(uuid())
  tenantId    String
  name        String
  slug        String
  type        String
  compliance  Int                    @default(0)
  status      String                 @default("watch")
  isDemo      Boolean                @default(false)
  seedKey     String?                @unique
  createdBy   String?                @default("system")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  buildings   Building[]
  memberships OrganizationMembership[]
  mandates    BuildingMandate[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("organizations")
}

model OrganizationMembership {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  roleKey        String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, roleKey])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_memberships")
}

model Building {
  id                   String              @id @default(uuid())
  tenantId             String
  organizationId       String?
  slug                 String
  buildingCode         String?
  name                 String
  timezone             String
  countryCode          String
  city                 String
  addressLine1         String
  street               String?
  buildingNumber       String?
  lat                  Float?
  lng                  Float?
  defaultContentLocale String              @default("en")
  defaultLanguage      String?
  supportedLanguages   String[]            @default([])
  type                 String              @default("Commercial")
  buildingType         String?
  primaryUse           String?
  secondaryUses        String[]            @default([])
  complexityFlags      String[]            @default([])
  yearBuilt            Int?
  floorsAboveGround    Int?
  floorsBelowGround    Int?
  floorsCount          Int?
  unitsCount           Int?
  entrancesCount       Int?
  liftsCount           Int?
  hasParking           Boolean?
  hasRestaurantsGroundFloor Boolean?
  hasRooftopMechanical Boolean?
  compliance           Int                 @default(0)
  mandates             Int                 @default(0)
  status               String              @default("warning")
  annualKwh            Float?
  notes                String?
  attributes           Json?
  isDemo               Boolean             @default(false)
  seedKey              String?             @unique
  createdBy            String?             @default("system")
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization       Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  assets             Asset[]
  buildingObligations BuildingObligation[]
  ppmTemplates       PpmTemplate[]
  ppmPlanItems       PpmPlanItem[]
  tasks              TaskInstance[]
  budgets            Budget[]
  invoices           Invoice[]
  approvals          ApprovalRequest[]
  approvalPolicies   ApprovalPolicy[]
  documents          Document[]
  audits             AuditEntry[]
  mandatesList       BuildingMandate[]
  roleAssignments    BuildingRoleAssignment[]
  engineeringRecs    EngineeringRecommendation[]
  projects           Project[]
  workOrders         WorkOrder[]
  takeoverCases      TakeoverCase[]
  entrances          Entrance[]
  floors             Floor[]
  units              Unit[]
  settings           BuildingSettings?
  accounts           Account[]
  contracts          Contract[]
  requests           ResidentRequest[]
  notifications      Notification[]
  buildingFloors     BuildingFloor[]
  buildingUnits      BuildingUnit[]
  verticalTransport  BuildingVerticalTransport[]
  buildingSystems    BuildingSystem[]
  occupantCompanies  BuildingOccupantCompany[]
  unitOccupancies    BuildingUnitOccupancy[]
  buildingContracts  BuildingContract[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([organizationId])
  @@map("buildings")
}

model Asset {
  id            String   @id @default(uuid())
  tenantId      String
  buildingId    String
  parentAssetId String?
  name          String
  class         String
  systemType    String?
  model         String?
  manufacturer  String?
  installDate   DateTime?
  attributes    Json?
  // Semantic model columns (SSOT §P4):
  //   haystackTags    — Project Haystack tag set (e.g. ["ahu","discharge","temp","sensor"])
  //   brickClass      — Brick ontology class URI (e.g. "brick:Supply_Air_Temperature_Sensor")
  //   brickRelations  — [{ predicate, object }] edges in Brick terms (e.g. isPointOf, feeds)
  //   externalIds     — { bacnet, opc, haystack, ifc } system-specific identifiers
  haystackTags   String[] @default([])
  brickClass     String?
  brickRelations Json?
  externalIds    Json?
  isDemo        Boolean  @default(false)
  seedKey       String?  @unique
  createdBy     String?  @default("system")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  parent   Asset?   @relation("AssetTree", fields: [parentAssetId], references: [id], onDelete: Cascade)
  children Asset[]  @relation("AssetTree")
  maintenancePlans MaintenancePlan[]

  @@index([tenantId, buildingId])
  @@index([parentAssetId])
  @@index([systemType])
  @@index([brickClass])
  @@map("assets")
}

model SensorPoint {
  id          String   @id @default(uuid())
  tenantId    String
  buildingId  String
  assetId     String
  name        String
  pointType   String   // temp | pressure | flow | co2 | power | status | setpoint | command
  unit        String?
  // Integration IDs
  bacnetId    String?  // e.g. "2:device-1024:AI:4"
  opcNodeId   String?  // OPC-UA NodeId (e.g. "ns=2;s=Channel.Device.Tag")
  haystackRef String?  // ^id or @id reference in a Haystack project
  haystackTags String[] @default([])
  brickClass  String?
  // Metadata
  minValue    Float?
  maxValue    Float?
  sampleRateS Int?    // expected sampling period (seconds)
  isActive    Boolean @default(true)
  isDemo      Boolean @default(false)
  seedKey     String? @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([buildingId, bacnetId])
  @@unique([buildingId, opcNodeId])
  @@index([tenantId, buildingId])
  @@index([assetId])
  @@index([brickClass])
  @@map("sensor_points")
}

model AlarmSource {
  id          String   @id @default(uuid())
  tenantId    String
  buildingId  String
  assetId     String
  name        String
  severity    String   @default("warning") // critical | warning | info
  source      String   // panel | bms | edge_gateway | controller | manual
  // Integration IDs
  bacnetId    String?
  opcNodeId   String?
  haystackRef String?
  haystackTags String[] @default([])
  brickClass  String?
  // Runtime state (optional denormalized fields; authoritative state lives in events)
  isActive    Boolean  @default(false)
  lastRaisedAt DateTime?
  lastClearedAt DateTime?
  isDemo      Boolean  @default(false)
  seedKey     String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, buildingId])
  @@index([assetId])
  @@index([severity, isActive])
  @@map("alarm_sources")
}

model ObligationTemplate {
  id                       String   @id @default(uuid())
  tenantId                 String
  assetId                  String?
  name                     String
  basisType                String
  recurrenceRule           String
  requiresEvidence         Boolean  @default(true)
  requiredCertificationKey String?
  requiredDocumentTypeKey  String?
  domain                   String?
  sourceRow                Int?
  isDemo                   Boolean  @default(false)
  seedKey                  String?  @unique
  createdBy                String?  @default("system")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  buildingLinks      BuildingObligation[]
  planItems          PpmPlanItem[]
  bases              ObligationBasis[]
  applicabilityRules ApplicabilityRule[]

  @@index([tenantId])
  @@index([domain])
  @@map("obligation_templates")
}

model ObligationBasis {
  id                   String @id @default(uuid())
  obligationTemplateId String
  type                 String
  referenceCode        String?
  issuingAuthority     String?

  obligationTemplate ObligationTemplate @relation(fields: [obligationTemplateId], references: [id], onDelete: Cascade)

  @@index([obligationTemplateId])
  @@map("obligation_bases")
}

model ApplicabilityRule {
  id                   String @id @default(uuid())
  obligationTemplateId String
  predicate            Json

  obligationTemplate ObligationTemplate @relation(fields: [obligationTemplateId], references: [id], onDelete: Cascade)

  @@index([obligationTemplateId])
  @@map("applicability_rules")
}

model BuildingObligation {
  id                 String   @id @default(uuid())
  tenantId           String
  buildingId         String
  obligationTemplateId String
  complianceStatus   String   @default("active")
  criticality        String   @default("medium")
  isDemo             Boolean  @default(false)
  seedKey            String?  @unique
  createdBy          String?  @default("system")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building    Building           @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  obligation  ObligationTemplate @relation(fields: [obligationTemplateId], references: [id], onDelete: Cascade)

  @@index([tenantId, buildingId])
  @@map("building_obligations")
}

model PpmTemplate {
  id                          String   @id @default(uuid())
  tenantId                    String
  buildingId                  String
  name                        String
  description                 String?
  instructions                String?
  domain                      String?
  scope                       String   @default("building_common") // building_common | unit_scoped
  executionMode               String   @default("in_house")        // in_house | contracted | ad_hoc_approved
  performerOrgId              String?
  contractId                  String?
  assignedUserId              String?
  assignedRole                String?
  approvalChain               Json?    // ordered: [{ role?, userId?, label? }]
  evidenceRecipients          Json?    // ordered: [{ role?, userId?, channel? }]
  openedByRoles               String[] @default([])
  closedByRoles               String[] @default([])
  slaReminderDays             Int[]    @default([])
  estimatedAnnualCost         Float?
  estimatedCostCurrency       String?  @default("ILS")
  budgetLineId                String?
  requiresPhotoEvidence       Boolean  @default(false)
  requiresSignoff             Boolean  @default(false)
  retentionYears              Int?
  requiresApprovalBeforeOrder Boolean  @default(false)
  frequencyMonths             Int?
  evidenceDocTypeKey          String?
  isDemo                      Boolean  @default(false)
  seedKey                     String?  @unique
  createdBy                   String?  @default("system")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building  Building     @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  planItems PpmPlanItem[]

  @@index([tenantId, buildingId])
  @@index([buildingId, scope])
  @@map("ppm_templates")
}

model PpmPlanItem {
  id                   String   @id @default(uuid())
  tenantId             String
  buildingId           String
  templateId           String
  obligationTemplateId String
  assignedRole         String
  assignedUserId       String?
  recurrenceRule       String
  nextDueAt            DateTime
  lastPerformedAt      DateTime?
  unitId               String?
  scope                String   @default("building_common")
  executionMode        String   @default("in_house")
  performerOrgId       String?
  contractId           String?
  isDemo               Boolean  @default(false)
  seedKey              String?  @unique
  createdBy            String?  @default("system")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building    Building           @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  template    PpmTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  obligation  ObligationTemplate @relation(fields: [obligationTemplateId], references: [id], onDelete: Cascade)
  tasks       TaskInstance[]

  @@index([tenantId, buildingId, nextDueAt])
  @@index([buildingId, scope])
  @@map("ppm_plan_items")
}

model TaskInstance {
  id                       String   @id @default(uuid())
  tenantId                 String
  buildingId               String
  planItemId               String?
  unitId                   String?
  title                    String
  status                   String
  lifecycleStage           String   @default("scheduled")
  executionMode            String?
  performerOrgId           String?
  dueAt                    DateTime
  completedAt              DateTime?
  completedByUserId        String?
  result                   String?
  recurrenceRule           String?
  evidenceRequired         Boolean  @default(false)
  evidenceDocuments        Json?
  blockedReason            String?
  requiredCertificationKey String?
  requiredDocumentTypeKey  String?
  quoteDocumentId          String?
  quoteAmount              Float?
  quoteCurrency            String?
  quoteReceivedAt          DateTime?
  approvalRequestId        String?
  approvedAt               DateTime?
  orderedAt                DateTime?
  serviceReportDocumentId  String?
  evidenceDistributedTo    Json?
  archivedAt               DateTime?
  isDemo                   Boolean  @default(false)
  seedKey                  String?  @unique
  createdBy                String?  @default("system")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  planItem PpmPlanItem? @relation(fields: [planItemId], references: [id], onDelete: SetNull)
  workOrders WorkOrder[]
  executionLogs PpmExecutionLog[]

  @@index([tenantId, buildingId, dueAt])
  @@index([status])
  @@index([lifecycleStage])
  @@map("task_instances")
}

model PpmExecutionLog {
  id         String   @id @default(uuid())
  tenantId   String
  buildingId String
  taskId     String
  actor      String
  eventType  String
  metadata   Json?
  createdAt  DateTime @default(now())

  task TaskInstance @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([tenantId, buildingId])
  @@map("ppm_execution_logs")
}

model Budget {
  id         String   @id @default(uuid())
  tenantId   String
  buildingId String
  name       String
  fiscalYear Int
  currency   String
  isDemo     Boolean  @default(false)
  seedKey    String?  @unique
  createdBy  String?  @default("system")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  lines    BudgetLine[]

  @@index([tenantId, buildingId])
  @@map("budgets")
}

model BudgetLine {
  id        String   @id @default(uuid())
  budgetId  String
  code      String
  name      String
  amount    Float
  isDemo    Boolean  @default(false)
  seedKey   String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget   Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([budgetId])
  @@map("budget_lines")
}

model Invoice {
  id               String   @id @default(uuid())
  tenantId         String
  buildingId       String
  budgetLineId     String?
  invoiceNo        String
  amount           Float
  status           String
  vendorName       String?
  isDemo           Boolean  @default(false)
  seedKey          String?  @unique
  createdBy        String?  @default("system")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building   Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  budgetLine BudgetLine? @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)

  @@index([tenantId, buildingId])
  @@map("invoices")
}

model ApprovalRequest {
  id              String   @id @default(uuid())
  tenantId        String
  buildingId      String
  title           String
  type            String
  amount          Float
  status          String
  requesterUserId String?
  requesterName   String?
  threshold       String?
  hint            String?
  isDemo          Boolean  @default(false)
  seedKey         String?  @unique
  createdBy       String?  @default("system")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building Building       @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  steps    ApprovalStep[]

  @@index([tenantId, buildingId, status])
  @@map("approval_requests")
}

model ApprovalStep {
  id            String   @id @default(uuid())
  requestId     String
  orderNo       Int
  role          String
  status        String
  actedByUserId String?
  actedAt       DateTime?
  // SSOT §P15: substitute / time-boxed delegation trail
  onBehalfOfUserId String?
  delegationId     String?
  waitingSinceAt   DateTime? @default(now())
  isDemo        Boolean  @default(false)
  seedKey       String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  request ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, orderNo])
  @@index([status])
  @@map("approval_steps")
}

// ─────────────────────────────────────────────────────────────────────
// SSOT §P15 — versioned approval policy templates + bounded delegation
// ─────────────────────────────────────────────────────────────────────
model ApprovalPolicy {
  id             String   @id @default(uuid())
  tenantId       String
  name           String
  type           String   // spend_approval | document_approval | compliance_approval
  buildingId     String?  // null = global / workspace-wide
  version        Int      @default(1)
  isActive       Boolean  @default(true)
  currency       String   @default("ILS")
  minAmount      Float    @default(0)
  maxAmount      Float?   // null = no upper bound
  stepsJson      Json     // [{ orderNo, role, mandatory: true, escalateAfterHours?: number }]
  effectiveFrom  DateTime @default(now())
  effectiveUntil DateTime?
  supersedesId   String?  // previous policy version this one replaces
  createdByUserId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building Building? @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, isActive])
  @@index([tenantId, buildingId, type])
  @@map("approval_policies")
}

model ApprovalDelegation {
  id               String   @id @default(uuid())
  tenantId         String
  delegatorUserId  String
  delegateUserId   String
  role             String   // role being delegated (maintenance_coordinator, finance_controller, ...)
  buildingId       String?  // null = applies across all buildings the delegator covers
  reason           String?
  startsAt         DateTime
  endsAt           DateTime
  revokedAt        DateTime?
  revokedByUserId  String?
  createdByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, delegateUserId, role])
  @@index([tenantId, delegatorUserId, role])
  @@index([tenantId, endsAt])
  @@map("approval_delegations")
}

model Document {
  id              String   @id @default(uuid())
  tenantId        String
  buildingId      String
  title           String
  documentType    String
  documentTypeKey String?
  status          String
  versionNo       Int      @default(1)
  storageKey      String
  // Content integrity & policy (SSOT §P7)
  sha256          String?
  mimeType        String?
  sizeBytes       Int?
  virusScanStatus String?  @default("pending") // pending | clean | infected | unscanned
  virusScanAt     DateTime?
  retentionClass  String?  // short | standard | statutory_7y | permanent
  retentionUntil  DateTime?
  legalHold       Boolean  @default(false)
  legalHoldReason String?
  legalHoldSetAt  DateTime?
  legalHoldSetBy  String?
  // Free-text search (populated by service with title + documentType + summary)
  searchText      String?
  createdBy       String?
  approvedBy      String?
  // SSOT §P13 — content lifecycle for time-bounded docs (insurance, KYC, license)
  expiresAt       DateTime?
  expiryAlertedAt DateTime?
  ownerOrgId      String?  // optional link to BuildingOccupantCompany / Organization owning the doc
  isDemo          Boolean  @default(false)
  seedKey         String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([tenantId, buildingId, status])
  @@index([documentTypeKey])
  @@index([sha256])
  @@index([legalHold])
  @@index([retentionUntil])
  @@index([expiresAt])
  @@map("documents")
}

model AuditEntry {
