  invokedByUserId   String
  invokedAt         DateTime  @default(now())
  ratificationDueBy DateTime
  ratifiedByUserId  String?
  ratifiedAt        DateTime?
  ratificationNotes String?
  status            String    @default("pending_ratification") // pending_ratification | ratified | lapsed | rejected
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tenantId, buildingId, status])
  @@index([targetType, targetId])
  @@index([ratificationDueBy])
  @@map("emergency_overrides")
}

model CompletionRecord {
