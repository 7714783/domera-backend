  documentId              String?
  // Three-way match result (populated on POST /vendor-invoices/:id/match)
  matchStatus             String    @default("unmatched") // unmatched | matched | over_amount | under_amount | no_completion | no_po | price_mismatch | disputed
  matchedPoAmount         Float?
  matchedCompletionAmount Float?
  matchedByUserId         String?
  matchedAt               DateTime?
  varianceNotes           String?
  approvalStatus          String    @default("pending") // pending | approved | rejected
  approvedByUserId        String?
