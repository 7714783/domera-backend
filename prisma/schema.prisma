  currency      String @default("USD")
  timezone      String @default("UTC")
  billingCycle  String @default("monthly")
  taxRules      Json?
  locale        String @default("en")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@map("building_settings")
}

model Vendor {
  id          String @id @default(uuid())
  tenantId    String
  name        String
  serviceType String?
  contactInfo Json?
  createdAt   DateTime @default(now())

  contracts Contract[]

  @@index([tenantId])
  @@map("vendors")
}

model Contract {
  id           String @id @default(uuid())
  tenantId     String
  buildingId   String
  vendorId     String
  startDate    DateTime
  endDate      DateTime?
  monthlyCost  Float?
  status       String   @default("active")
  createdAt    DateTime @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  vendor   Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([tenantId, buildingId])
  @@map("contracts")
}

model Account {
  id         String @id @default(uuid())
  tenantId   String
  buildingId String
  type       String
  balance    Float  @default(0)
  currency   String @default("USD")
  createdAt  DateTime @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([tenantId, buildingId])
  @@map("accounts")
}

model MaintenancePlan {
  id         String @id @default(uuid())
  tenantId   String
  buildingId String
  assetId    String
  frequency  String
  nextDueAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([tenantId, buildingId])
  @@map("maintenance_plans")
}

model ResidentRequest {
  id          String @id @default(uuid())
  tenantId    String
  buildingId  String
  unitId      String?
  createdBy   String
  category    String
  priority    String  @default("normal")
  status      String  @default("open")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([tenantId, buildingId, status])
  @@map("resident_requests")
}

model Notification {
  id         String @id @default(uuid())
  tenantId   String
  buildingId String?
  userId     String
  type       String
  content    String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  building Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  @@index([tenantId, userId, readAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────
// Building Core v1 — first-building-first, multi-building-ready
// All rows carry tenantId + buildingId. Each concern lives in its
// own table instead of a giant JSON blob on `buildings`.
// ─────────────────────────────────────────────────────────────

model BuildingFloor {
  id           String   @id @default(uuid())
  tenantId     String
  buildingId   String
  floorCode    String
  floorNumber  Int
  floorType    String
  label        String?
  isActive     Boolean  @default(true)
  grossAreaSqm Float?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  building Building       @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  units    BuildingUnit[]
  systems  BuildingSystem[]

  @@unique([buildingId, floorCode])
  @@index([tenantId, buildingId, floorNumber])
  @@map("building_floors")
}

model BuildingUnit {
  id          String   @id @default(uuid())
  tenantId    String
  buildingId  String
  floorId     String
  unitCode    String
  unitType    String
  areaSqm     Float?
  layoutZone  String?
  isDivisible Boolean  @default(false)
  status      String   @default("vacant")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  building    Building               @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor       BuildingFloor          @relation(fields: [floorId], references: [id], onDelete: Cascade)
  occupancies BuildingUnitOccupancy[]
  contracts   BuildingContract[]

  @@unique([buildingId, unitCode])
  @@index([tenantId, buildingId, floorId])
  @@map("building_units")
}

model BuildingVerticalTransport {
  id              String   @id @default(uuid())
  tenantId        String
  buildingId      String
  code            String
  transportType   String
  servesFromFloor Int
  servesToFloor   Int
  quantity        Int      @default(1)
  status          String   @default("active")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([buildingId, code])
  @@index([tenantId, buildingId, transportType])
  @@map("building_vertical_transport")
}

model BuildingSystem {
  id             String   @id @default(uuid())
  tenantId       String
  buildingId     String
  systemCategory String
  systemCode     String
  name           String
  locationType   String?
  floorId        String?
  quantity       Int?
  status         String   @default("active")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  building Building       @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor    BuildingFloor? @relation(fields: [floorId], references: [id], onDelete: SetNull)

  @@unique([buildingId, systemCode])
  @@index([tenantId, buildingId, systemCategory])
  @@map("building_systems")
}

model BuildingOccupantCompany {
  id           String   @id @default(uuid())
  tenantId     String
  buildingId   String
  companyName  String
  companyType  String?
  contactName  String?
  phone        String?
  email        String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  building    Building                @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  occupancies BuildingUnitOccupancy[]
  contracts   BuildingContract[]

  @@index([tenantId, buildingId])
  @@map("building_occupant_companies")
}

model BuildingUnitOccupancy {
  id                 String    @id @default(uuid())
  tenantId           String
  buildingId         String
  unitId             String
  occupantCompanyId  String
  startDate          DateTime?
  endDate            DateTime?
  occupancyStatus    String    @default("active")
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  building         Building                @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit             BuildingUnit            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  occupantCompany  BuildingOccupantCompany @relation(fields: [occupantCompanyId], references: [id], onDelete: Cascade)

  @@index([tenantId, buildingId, unitId])
  @@index([occupantCompanyId])
  @@map("building_unit_occupancies")
}

model BuildingContract {
  id                String    @id @default(uuid())
  tenantId          String
  buildingId        String
  occupantCompanyId String
  unitId            String?
  contractType      String
  contractNumber    String?
  startDate         DateTime?
  endDate           DateTime?
  status            String    @default("draft")
  amount            Float?
  currency          String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // SSOT §P13 — escalation policy: { type: 'cpi'|'fixed_pct'|'stepped',
  // ratePct?: number, indexBase?: string, schedule?: [{ atMonth: number, ratePct: number }] }
  escalationPolicy Json?
  paymentFrequency String   @default("monthly") // monthly | quarterly | yearly
  noticePeriodDays Int?
  insuranceDocumentId String?

  building         Building                @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  occupantCompany  BuildingOccupantCompany @relation(fields: [occupantCompanyId], references: [id], onDelete: Cascade)
  unit             BuildingUnit?           @relation(fields: [unitId], references: [id], onDelete: SetNull)
  allocations      LeaseAllocation[]

  @@index([tenantId, buildingId, contractType])
  @@index([occupantCompanyId])
  @@map("building_contracts")
}

// SSOT §P13 — single contract can cover multiple billable items: extra units,
// parking spots, storage. Replaces hard-coded one-unit assumption.
model LeaseAllocation {
  id            String  @id @default(uuid())
  tenantId      String
  contractId    String
  targetType    String  // unit | parking_spot | storage_unit
  targetId      String
  share         Float   @default(1.0)  // 0..1 portion of monthly amount apportioned here
  monthlyAmount Float   @default(0)
  currency      String  @default("ILS")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contract BuildingContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([tenantId, contractId])
  @@index([tenantId, targetType, targetId])
  @@map("lease_allocations")
}

// SSOT §P11 — links a platform User to an occupying company so the user can
// open the tenant self-service view scoped to their company.
model TenantRepresentative {
  id                String   @id @default(uuid())
  tenantId          String
  buildingId        String
  occupantCompanyId String
  userId            String
  role              String   @default("primary_contact") // primary_contact | building_committee | finance_contact
  status            String   @default("active")          // active | revoked
  invitedByUserId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([occupantCompanyId, userId])
  @@index([tenantId, userId])
  @@index([tenantId, buildingId])
  @@map("tenant_representatives")
}

model SeedRun {
  id          String   @id @default(uuid())
  tenantId    String?
  seedName    String
  seedVersion String
  status      String
  checksum    String
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  createdBy   String   @default("seed:test-building")
  errorText   String?

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([seedName, seedVersion])
  @@map("seed_runs")
}
