  @@map("vendor_invoices")
}

// Calendar blackout: dates/ranges on which PPM `nextDueAt` should be rolled
// forward. Used to encode local weekends (e.g. Israel: Saturday) + statutory
// holidays + tenant-specific maintenance freeze windows.
model CalendarBlackout {
  id          String   @id @default(uuid())
  tenantId    String
  buildingId  String?  // null = tenant-wide
  kind        String   // weekend | holiday | freeze | custom
  label       String
  // Recurring weekly: dayOfWeek (0=Sun..6=Sat). If set, startDate/endDate ignored.
  dayOfWeek   Int?
  // One-shot / annual: inclusive range. If annualRecurring=true, the month+day
  // pattern repeats every year (startDate's year is ignored).
  startDate   DateTime?
  endDate     DateTime?
  annualRecurring Boolean  @default(false)
  // When a due date hits a blackout: shift | skip | defer_to_next_working_day
  policy      String   @default("defer_to_next_working_day")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, buildingId, isActive])
  @@index([dayOfWeek])
  @@map("calendar_blackouts")
}

// Condition-based PPM trigger: when a SensorPoint reading crosses the
// threshold, spawn an ad-hoc TaskInstance from the bound PpmTemplate.
// This is the "predictive maintenance" edge of P6.
model ConditionTrigger {
  id           String   @id @default(uuid())
  tenantId     String
  buildingId   String
  sensorPointId String
  templateId   String
  name         String
  // Threshold semantics: operator applied to reading vs value.
  operator     String   // gt | gte | lt | lte | eq | ne | crossing
  threshold    Float
  unit         String?
  // De-duplication: don't spawn a new task if another fired within the window.
  cooldownMinutes Int   @default(60)
  isActive     Boolean  @default(true)
  lastFiredAt  DateTime?
  lastReadingValue Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, buildingId, isActive])
  @@index([sensorPointId])
  @@index([templateId])
  @@map("condition_triggers")
}

// Audit log of every evaluated sensor reading that flipped a trigger —
// whether or not it actually spawned a task (may be de-duped by cooldown).
model ConditionEvent {
  id           String   @id @default(uuid())
  tenantId     String
  buildingId   String
  triggerId    String
  sensorPointId String
  readingValue Float
  readingAt    DateTime
  action       String   // spawned_task | deduped_cooldown | threshold_not_met
  taskInstanceId String?
  notes        String?
  createdAt    DateTime @default(now())

  @@index([tenantId, triggerId, readingAt])
  @@index([action])
  @@map("condition_events")
}

// Emergency override (break-glass): allows bypassing normal SoD/approval
// chains for P1 incidents; requires post-facto ratification within a window.
model EmergencyOverride {
  id               String    @id @default(uuid())
  tenantId         String
  buildingId       String
  targetType       String    // purchase_order | work_order | completion | task_instance | quote
  targetId         String
  reason           String
  severity         String    @default("P1") // P1 | P2
  invokedByUserId  String
  invokedAt        DateTime  @default(now())
  ratificationDueBy DateTime
  ratifiedByUserId String?
  ratifiedAt       DateTime?
  ratificationNotes String?
  status           String    @default("pending_ratification") // pending_ratification | ratified | lapsed | rejected
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tenantId, buildingId, status])
  @@index([targetType, targetId])
  @@index([ratificationDueBy])
  @@map("emergency_overrides")
}

