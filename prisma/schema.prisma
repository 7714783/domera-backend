// ─── Reactive workflow (P8): Incident / ServiceRequest / Quote / PO / Completion ───

model Incident {
  id               String    @id @default(uuid())
  tenantId         String
  buildingId       String
  unitId           String?
  equipmentId      String?
  title            String
  description      String?
  severity         String // P1 | P2 | P3 | P4
  status           String    @default("new") // new | triaged | dispatched | resolved | archived
  origin           String // bms | human | qr | email | api | sensor
  reportedBy       String?
  reportedAt       DateTime  @default(now())
  ackedAt          DateTime?
  resolvedAt       DateTime?
  rootCause        String?
  preventiveAction String?
  workOrderId      String?
  // INIT-004 — auto-assignment outcome captured at create time.
  // assignedUserId points at the resolved User; assignmentSource records
  // why ('auto' / 'manager' / 'self' / 'unassigned'); assignmentReason is
  // human-readable ("primary cleaner present" / "all coverers absent").
  assignedUserId   String?
  assignmentSource String?
  assignmentReason String?
  floorId          String?
  // INIT-007 Phase 4 — TenantCompany scope. Lets a TENANT_COMPANY_ADMIN
  // see only their own company's incidents and a TENANT_EMPLOYEE see
  // only the ones they created. NULL = not associated with any company.
  tenantCompanyId  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tenantId, buildingId, status])
  @@index([severity])
  @@index([assignedUserId])
  @@index([tenantCompanyId])
  @@map("incidents")
}

