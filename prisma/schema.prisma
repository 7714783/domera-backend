model PpmPlanItem {
  id                         String    @id @default(uuid())
  tenantId                   String
  buildingId                 String
  templateId                 String
  obligationTemplateId       String
  assignedRole               String
  assignedUserId             String?
  recurrenceRule             String
  nextDueAt                  DateTime
  lastPerformedAt            DateTime?
  unitId                     String?
  scope                      String    @default("building_common")
  executionMode              String    @default("in_house")
  performerOrgId             String?
  contractId                 String?
  // Baseline state — whether this plan item has been onboarded into the
  // main scheduled flow.
  //   pending  — no baseline yet; excluded from the scheduler / compliance
  //              / triage surfaces. Awaits operator action on the Setup page.
  //   set      — baseline recorded (lastPerformedAt + evidence); main flow.
  //   unknown  — operator declared the prior record unknown; forced into
  //              main flow with immediate due date. Evidence may be filled
  //              later by a back-dated completion.
  baselineStatus             String    @default("pending")
  baselineSetAt              DateTime?
  baselineSetByUserId        String?
  baselineEvidenceDocumentId String?
  baselineNote               String?
  // Optional link to an Asset — when the plan item is scoped to a specific
  // piece of equipment (e.g. AHU-01) rather than the whole building or a unit.
  assetId                    String?
  isDemo                     Boolean   @default(false)
  seedKey                    String?   @unique
  createdBy                  String?   @default("system")
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building   Building           @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  template   PpmTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  obligation ObligationTemplate @relation(fields: [obligationTemplateId], references: [id], onDelete: Cascade)
  asset      Asset?             @relation("AssetPpmPlanItems", fields: [assetId], references: [id], onDelete: SetNull)
  tasks      TaskInstance[]

  @@index([tenantId, buildingId, nextDueAt])
  @@index([buildingId, scope])
  @@index([assetId])
  // DB-level uniqueness enforced via two PARTIAL indexes declared in
  // apps/api/prisma/migrations-sql/001_ppm_plan_item_unique.sql:
  //   ppm_plan_items_unique_scope_no_unit
  //     UNIQUE(tenantId, buildingId, obligationTemplateId, scope) WHERE unitId IS NULL
  //   ppm_plan_items_unique_scope_unit
  //     UNIQUE(tenantId, buildingId, obligationTemplateId, scope, unitId) WHERE unitId IS NOT NULL
  // Prisma @@unique cannot express the WHERE clause, so the indexes live in a
  // raw-SQL migration. The app-level pre-check in PpmService still catches
  // the common case and returns a user-friendly error; the partial indexes
  // close the race window.
  @@map("ppm_plan_items")
}

