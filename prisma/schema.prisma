generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Compliance profiles (P5): per-jurisdiction / per-building rule bundles ──
model ComplianceProfile {
  id                    String   @id @default(uuid())
  tenantId              String
  key                   String // "IL-SI1525", "ASHRAE180", "NFPA25", custom
  name                  String
  jurisdiction          String? // ISO country code or "global"
  description           String?
  domains               String[] @default([])
  obligationTemplateIds String[] @default([])
  isActive              Boolean  @default(true)
  isBuiltIn             Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  assignments BuildingComplianceProfile[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("compliance_profiles")
}

model BuildingComplianceProfile {
  id         String   @id @default(uuid())
  tenantId   String
  buildingId String
  profileId  String
  assignedAt DateTime @default(now())
  assignedBy String?

  profile ComplianceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([buildingId, profileId])
  @@index([tenantId, buildingId])
  @@map("building_compliance_profiles")
}

model Tenant {
  id                   String                @id @default(uuid())
  slug                 String                @unique
  name                 String
  status               String                @default("active")
  storageMode          String                @default("pooled")
  defaultUiLocale      String                @default("en")
  defaultContentLocale String                @default("en")
  timezone             String                @default("UTC")
  isDemo               Boolean               @default(false)
  seedKey              String?               @unique
  createdBy            String?               @default("system")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  memberships          Membership[]
  buildings            Building[]
  organizations        Organization[]
  obligations          ObligationTemplate[]
  buildingObligations  BuildingObligation[]
  ppmTemplates         PpmTemplate[]
  ppmPlanItems         PpmPlanItem[]
  tasks                TaskInstance[]
  budgets              Budget[]
  invoices             Invoice[]
  approvals            ApprovalRequest[]
  documents            Document[]
  audits               AuditEntry[]
  assets               Asset[]
  seedRuns             SeedRun[]
  approvalPolicies     ApprovalPolicy[]
  approvalDelegations  ApprovalDelegation[]
  devices              Device[]
  teamMembers          TeamMember[]
  workspaceContractors WorkspaceContractor[]
  customRoles          Role[]                @relation("TenantCustomRoles")

  @@map("tenants")
}

// ── INIT-013 Roles & Team module ───────────────────────────────────────
//
// PublicContractor — global registry, NOT tenant-scoped. Holds public-only
// info that contractor companies are happy to expose: name, public phone /
// email, licenses, specialisations, optional rating, country/city. Workspaces
// link to it via WorkspaceContractor (tenant-scoped) where they store private
// notes / preferred rate / internal rating.
//
// One PublicContractor row may be referenced by N WorkspaceContractor rows
// across N workspaces — no leakage because every per-workspace state lives
// on the tenant-scoped link table.
model PublicContractor {
  id                String   @id @default(uuid())
  displayName       String
  legalName         String?
  publicPhone       String?
  publicEmail       String?
  website           String?
  country           String?
  city              String?
  // Free-form specialisations: ['hvac', 'fire_safety', 'cleaning', 'security'].
  specialisations   String[] @default([])
  // License / certificate strings ('IEC-electrical', 'NFPA-25', …).
  licenses          String[] @default([])
  // Optional 0..5 average rating, computed off-band; nullable while empty.
  ratingAvg         Float?
  ratingCount       Int      @default(0)
  // Verification status: 'unverified' | 'self_attested' | 'platform_verified'.
  // Only platform_verified rows show a "trust badge" cross-workspace.
  verificationState String   @default("unverified")
  // Tenant that first created this entry — informational only.
  createdByTenantId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspaceLinks WorkspaceContractor[]

  @@index([displayName])
  @@index([publicPhone])
  @@index([publicEmail])
  @@map("public_contractors")
}

// WorkspaceContractor — per-workspace link to a PublicContractor. Stores
// the relationship-specific data that must NEVER leak cross-workspace:
// preferred contact within the workspace, private notes, agreed rate,
// internal rating, contract start/end. Tenant-scoped (RLS enforced).
model WorkspaceContractor {
  id                  String    @id @default(uuid())
  tenantId            String
  publicContractorId  String
  // Local override of the display name used inside this workspace
  // (a workspace may know the same firm under a project nickname).
  localDisplayName    String?
  // Internal contact person — *separate* from the public phone. Often a
  // specific manager who deals with this workspace's properties.
  localContactPerson  String?
  localContactPhone   String?
  localContactEmail   String?
  // Free-form private notes. NEVER returned to other tenants.
  privateNotes        String?
  preferredRate       String?
  internalRatingAvg   Float?
  internalRatingCount Int       @default(0)
  startedAt           DateTime?
  endedAt             DateTime?
  status              String    @default("active") // active | paused | terminated
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  publicContractor PublicContractor @relation(fields: [publicContractorId], references: [id], onDelete: Restrict)
  teamMembers      TeamMember[]

  @@unique([tenantId, publicContractorId])
  @@index([tenantId])
  @@index([publicContractorId])
  @@map("workspace_contractors")
}

// TeamMember — single source of people inside a workspace. Every person
// who can be assigned to a task / approve a document / receive an alert
// MUST exist as a TeamMember.
//
// Two kinds:
//   · 'employee'   — has an associated User account (login + permissions).
//   · 'contractor' — links to WorkspaceContractor (no User required, may
//     be just a phone contact). May still be promoted to a User later.
//
// Deactivation flow: setting `isActive=false` triggers a cascade that
// revokes all TeamMemberRoleAssignment rows + reassigns their open tasks
// to the workspace_owner unassigned queue. The TeamMember row stays for
// audit history.
model TeamMember {
  id                    String    @id @default(uuid())
  tenantId              String
  kind                  String    @default("employee") // employee | contractor | external
  // Optional User link. NULL for contractor-without-account contacts.
  // Unique per tenant: one User → at most one TeamMember in this workspace.
  userId                String?
  // Optional WorkspaceContractor link (only meaningful when kind=contractor).
  workspaceContractorId String?
  // Display attributes — primary source of truth for assignee names in UI.
  displayName           String
  email                 String?
  phone                 String?
  title                 String?
  department            String?
  photoUrl              String?
  isActive              Boolean   @default(true)
  startDate             DateTime?
  endDate               DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspaceContractor WorkspaceContractor?       @relation(fields: [workspaceContractorId], references: [id], onDelete: SetNull)
  roleAssignments     TeamMemberRoleAssignment[]

  @@unique([tenantId, userId])
  @@index([tenantId, isActive])
  @@index([tenantId, kind])
  @@map("team_members")
}

// TeamMemberRoleAssignment — primary role grant going forward.
// Replaces BuildingRoleAssignment for new code (legacy table kept for
// backwards compatibility during migration period — backfilled in 017).
//
// `roleKey` references either a system role (Role.tenantId IS NULL) or
// a custom role owned by this tenant (Role.tenantId = self).
//
// Scope dimensions are additive — empty = unrestricted within the
// workspace, set = narrowing. The auto-routing resolver intersects the
// task context with the assignment scope to find eligible members.
model TeamMemberRoleAssignment {
  id                  String    @id @default(uuid())
  tenantId            String
  teamMemberId        String
  roleKey             String
  // Building scope — empty = all buildings; otherwise a positive list.
  buildingIds         String[]  @default([])
  // ABAC scope dimensions (same shape as legacy BuildingRoleAssignment).
  floorIds            String[]  @default([])
  zoneIds             String[]  @default([])
  systemIds           String[]  @default([])
  teamId              String?
  contractorCompanyId String?
  tenantCompanyId     String?
  createdByScope      Boolean   @default(false)
  delegatedBy         String?
  delegatedAt         DateTime  @default(now())
  expiresAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  teamMember TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  role       Role       @relation("TeamRoleGrants", fields: [roleKey], references: [key], onDelete: Cascade)

  @@unique([teamMemberId, roleKey])
  @@index([tenantId])
  @@index([roleKey])
  @@index([expiresAt])
  @@map("team_member_role_assignments")
}

model User {
  id                      String                   @id @default(uuid())
  email                   String
  emailNormalized         String                   @unique
  username                String?                  @unique
  passwordHash            String?
  displayName             String?
  status                  String                   @default("active")
  isSuperAdmin            Boolean                  @default(false)
  lastLoginAt             DateTime?
  isDemo                  Boolean                  @default(false)
  seedKey                 String?                  @unique
  createdBy               String?                  @default("system")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  memberships             Membership[]
  organizationMemberships OrganizationMembership[]
  buildingRoles           BuildingRoleAssignment[]
  certifications          UserCertification[]
  sessions                Session[]
  teamMemberships         TeamMember[]
  devices                 Device[]

  @@map("users")
}

model Session {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  revokedBy  String?
  userAgent  String?
  ipAddress  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Membership {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  roleKey   String
  status    String   @default("active")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, roleKey])
  @@index([tenantId, userId])
  @@map("memberships")
}

model Organization {
  id              String                   @id @default(uuid())
  tenantId        String
  name            String
  slug            String
  type            String
  compliance      Int                      @default(0)
  status          String                   @default("watch")
  isDemo          Boolean                  @default(false)
  seedKey         String?                  @unique
  createdBy       String?                  @default("system")
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  buildings       Building[]
  memberships     OrganizationMembership[]
  mandates        BuildingMandate[]
  vendorContracts BuildingContract[]       @relation("BuildingContractVendor")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("organizations")
}

model OrganizationMembership {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  roleKey        String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, roleKey])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_memberships")
}

model Building {
  id                        String    @id @default(uuid())
  tenantId                  String
  organizationId            String?
  slug                      String
  buildingCode              String?
  name                      String
  timezone                  String
  countryCode               String
  city                      String
  addressLine1              String
  street                    String?
  buildingNumber            String?
  lat                       Float?
  lng                       Float?
  defaultContentLocale      String    @default("en")
  defaultLanguage           String?
  supportedLanguages        String[]  @default([])
  type                      String    @default("Commercial")
  buildingType              String?
  primaryUse                String?
  secondaryUses             String[]  @default([])
  complexityFlags           String[]  @default([])
  yearBuilt                 Int?
  floorsAboveGround         Int?
  floorsBelowGround         Int?
  floorsCount               Int?
  unitsCount                Int?
  entrancesCount            Int?
  liftsCount                Int?
  hasParking                Boolean?
  hasRestaurantsGroundFloor Boolean?
  hasRooftopMechanical      Boolean?
  compliance                Int       @default(0)
  mandates                  Int       @default(0)
  // Operational health indicator (compliance / overdue / etc.) — keep
  // separate from the lifecycleStatus below.
  status                    String    @default("warning")
  // INIT-012 Phase 2 — building lifecycle.
  //   draft     — freshly created during onboarding wizard; partial data;
  //               only visible to managers; published when flipped to active.
  //   active    — operational; default state.
  //   archived  — decommissioned; read-only; excluded from listings by
  //               default. Different from full deletion — archived keeps
  //               history viewable; DELETE /v1/buildings/:slug removes it.
  lifecycleStatus           String    @default("active")
  publishedAt               DateTime?
  archivedAt                DateTime?
  annualKwh                 Float?
  notes                     String?
  attributes                Json?
  isDemo                    Boolean   @default(false)
  seedKey                   String?   @unique
  createdBy                 String?   @default("system")
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  tenant              Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization        Organization?               @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  assets              Asset[]
  buildingObligations BuildingObligation[]
  ppmTemplates        PpmTemplate[]
  ppmPlanItems        PpmPlanItem[]
  tasks               TaskInstance[]
  budgets             Budget[]
  invoices            Invoice[]
  approvals           ApprovalRequest[]
  approvalPolicies    ApprovalPolicy[]
  documents           Document[]
  audits              AuditEntry[]
  mandatesList        BuildingMandate[]
  roleAssignments     BuildingRoleAssignment[]
  engineeringRecs     EngineeringRecommendation[]
  projects            Project[]
  workOrders          WorkOrder[]
  takeoverCases       TakeoverCase[]
  entrances           Entrance[]
  floors              Floor[]
  units               Unit[]
  settings            BuildingSettings?
  accounts            Account[]
  contracts           Contract[]
  requests            ResidentRequest[]
  notifications       Notification[]
  buildingFloors      BuildingFloor[]
  buildingUnits       BuildingUnit[]
  buildingUnitGroups  BuildingUnitGroup[]
  verticalTransport   BuildingVerticalTransport[]
  buildingSystems     BuildingSystem[]
  occupantCompanies   BuildingOccupantCompany[]
  unitOccupancies     BuildingUnitOccupancy[]
  buildingContracts   BuildingContract[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([organizationId])
  @@map("buildings")
}

// Asset (building operational registry). Supports two modes:
//   - serialized unit/component: serial number, unique item
//   - group/zone asset:           zonal / linear / area without serial
model Asset {
  id                    String    @id @default(uuid())
  tenantId              String
  buildingId            String
  parentAssetId         String?
  assetTypeId           String? // FK to AssetType (taxonomy)
  locationId            String? // FK to canonical BuildingLocation
  qrBarcode             String?   @unique
  name                  String
  class                 String // legacy coarse class (kept for backward-compat)
  systemType            String? // legacy subsystem label
  systemFamily          String? // canonical: HVAC | Electrical | Fire | Lift | Water | …
  assetLevel            String    @default("unit") // system | subsystem | unit | component | group | zone
  model                 String?
  manufacturer          String?
  manufacturerPartNo    String?
  serialNumber          String?
  installDate           DateTime?
  commissioningDate     DateTime?
  warrantyStart         DateTime?
  warrantyEnd           DateTime?
  attributes            Json?
  // Lifecycle + responsibility
  lifecycleStatus       String    @default("active") // planned | active | standby | out_of_service | obsolete | disposed
  conditionState        String    @default("good") // good | fair | poor | critical
  riskCriticality       String    @default("medium") // low | medium | high | life_safety | mission_critical
  responsibleDepartment String?
  responsibleUserId     String?
  // Commercial
  purchaseCost          Float?
  replacementCost       Float?
  contractId            String?
  slaId                 String?
  // Semantic model columns (SSOT §P4):
  haystackTags          String[]  @default([])
  brickClass            String?
  brickRelations        Json?
  externalIds           Json?
  ifcGuid               String?
  isActive              Boolean   @default(true)
  isDemo                Boolean   @default(false)
  seedKey               String?   @unique
  createdBy             String?   @default("system")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building         Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  parent           Asset?            @relation("AssetTree", fields: [parentAssetId], references: [id], onDelete: Cascade)
  children         Asset[]           @relation("AssetTree")
  maintenancePlans MaintenancePlan[]
  ppmPlanItems     PpmPlanItem[]     @relation("AssetPpmPlanItems")

  @@index([tenantId, buildingId])
  @@index([parentAssetId])
  @@index([systemType])
  @@index([brickClass])
  @@index([assetTypeId])
  @@index([locationId])
  @@index([systemFamily])
  @@index([riskCriticality])
  @@index([lifecycleStatus])
  @@map("assets")
}

// Asset taxonomy — tenant-scoped, extensible. Seeded with the canonical
// building-ops taxonomy (HVAC/Electrical/Fire/Lift/Water/Comms/Security/
// Envelope/Roof/Sanitary/...).
model AssetType {
  id           String   @id @default(uuid())
  tenantId     String
  key          String // stable key, e.g. "hvac.ahu"
  name         String
  systemFamily String // HVAC | Electrical | Fire | Lift | Water | Comms | Security | Envelope | Roof | Sanitary | Service | Monitoring
  isSerialized Boolean  @default(true) // serialized unit vs group/zone
  schemaKey    String? // links to JSON Schema for typed custom attrs
  description  String?
  isBuiltIn    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, systemFamily, isActive])
  @@map("asset_types")
}

// Custom typed attributes per asset. Value stored as JSON to keep schema
// flexible while preserving indexable `attributeKey` on hot paths.
model AssetCustomAttribute {
  id           String   @id @default(uuid())
  tenantId     String
  assetId      String
  attributeKey String
  valueType    String   @default("string") // string | number | integer | boolean | date | json
  valueJson    Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([assetId, attributeKey])
  @@index([tenantId, attributeKey])
  @@map("asset_custom_attributes")
}

// Document attachments for assets (paspoort, O&M manual, as-built drawings).
// Different from DocumentLink (polymorphic) — this is a typed direct link
// that the asset detail page reads to render the Documents tab fast.
model AssetDocument {
  id         String   @id @default(uuid())
  tenantId   String
  assetId    String
  documentId String
  docType    String // o_m_manual | as_built | certificate | warranty | datasheet | photo | schema | other
  title      String?
  version    String?
  createdAt  DateTime @default(now())

  @@unique([assetId, documentId, docType])
  @@index([tenantId, assetId])
  @@index([documentId])
  @@map("asset_documents")
}

// Photos/media attached to an asset (nameplate shot, installed-position
// shot, condition-evidence shot). Stored as object-storage URLs in the
// existing Document table, but surfaced here so that each media item can
// carry a caption + mediaType without polluting Document itself.
model AssetMedia {
  id         String   @id @default(uuid())
  tenantId   String
  assetId    String
  mediaType  String // photo | drawing | diagram | video
  documentId String? // optional link to a stored Document
  url        String? // or a direct URL (for external refs)
  caption    String?
  createdAt  DateTime @default(now())

  @@index([tenantId, assetId])
  @@map("asset_media")
}

// Spare parts catalogue (tenant-scoped). Spare parts are their own
// entities in inventory and get linked to one or more asset types (or
// specific assets) via AssetSparePart.
model SparePart {
  id           String   @id @default(uuid())
  tenantId     String
  partNo       String
  name         String
  manufacturer String?
  supplierId   String?
  unit         String?  @default("pc")
  reorderPoint Int?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, partNo])
  @@index([tenantId, supplierId])
  @@map("spare_parts")
}

// Many-to-many: which spare parts are recommended for a given asset.
model AssetSparePart {
  id             String   @id @default(uuid())
  tenantId       String
  assetId        String
  partId         String
  qtyRecommended Float    @default(1)
  notes          String?
  createdAt      DateTime @default(now())

  @@unique([assetId, partId])
  @@index([tenantId, assetId])
  @@index([partId])
  @@map("asset_spare_parts")
}

model SensorPoint {
  id           String   @id @default(uuid())
  tenantId     String
  buildingId   String
  assetId      String
  name         String
  pointType    String // temp | pressure | flow | co2 | power | status | setpoint | command
  unit         String?
  // Integration IDs
  bacnetId     String? // e.g. "2:device-1024:AI:4"
  opcNodeId    String? // OPC-UA NodeId (e.g. "ns=2;s=Channel.Device.Tag")
  haystackRef  String? // ^id or @id reference in a Haystack project
  haystackTags String[] @default([])
  brickClass   String?
  // Metadata
  minValue     Float?
  maxValue     Float?
  sampleRateS  Int? // expected sampling period (seconds)
  isActive     Boolean  @default(true)
  isDemo       Boolean  @default(false)
  seedKey      String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([buildingId, bacnetId])
  @@unique([buildingId, opcNodeId])
  @@index([tenantId, buildingId])
  @@index([assetId])
  @@index([brickClass])
  @@map("sensor_points")
}

model AlarmSource {
  id            String    @id @default(uuid())
  tenantId      String
  buildingId    String
  assetId       String
  name          String
  severity      String    @default("warning") // critical | warning | info
  source        String // panel | bms | edge_gateway | controller | manual
  // Integration IDs
  bacnetId      String?
  opcNodeId     String?
  haystackRef   String?
  haystackTags  String[]  @default([])
  brickClass    String?
  // Runtime state (optional denormalized fields; authoritative state lives in events)
  isActive      Boolean   @default(false)
  lastRaisedAt  DateTime?
  lastClearedAt DateTime?
  isDemo        Boolean   @default(false)
  seedKey       String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, buildingId])
  @@index([assetId])
  @@index([severity, isActive])
  @@map("alarm_sources")
}

model ObligationTemplate {
  id                       String   @id @default(uuid())
  tenantId                 String
  assetId                  String?
  name                     String
  basisType                String
  recurrenceRule           String
  requiresEvidence         Boolean  @default(true)
  requiredCertificationKey String?
  requiredDocumentTypeKey  String?
  domain                   String?
  sourceRow                Int?
  isDemo                   Boolean  @default(false)
  seedKey                  String?  @unique
  createdBy                String?  @default("system")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  buildingLinks      BuildingObligation[]
  planItems          PpmPlanItem[]
  bases              ObligationBasis[]
  applicabilityRules ApplicabilityRule[]

  @@index([tenantId])
  @@index([domain])
  @@map("obligation_templates")
}

model ObligationBasis {
  id                   String  @id @default(uuid())
  obligationTemplateId String
  type                 String
  referenceCode        String?
  issuingAuthority     String?

  obligationTemplate ObligationTemplate @relation(fields: [obligationTemplateId], references: [id], onDelete: Cascade)

  @@index([obligationTemplateId])
  @@map("obligation_bases")
}

model ApplicabilityRule {
  id                   String @id @default(uuid())
  obligationTemplateId String
  predicate            Json

  obligationTemplate ObligationTemplate @relation(fields: [obligationTemplateId], references: [id], onDelete: Cascade)

  @@index([obligationTemplateId])
  @@map("applicability_rules")
}

model BuildingObligation {
  id                   String   @id @default(uuid())
  tenantId             String
  buildingId           String
  obligationTemplateId String
  complianceStatus     String   @default("active")
  criticality          String   @default("medium")
  isDemo               Boolean  @default(false)
  seedKey              String?  @unique
  createdBy            String?  @default("system")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
