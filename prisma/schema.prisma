  createdAt  DateTime  @default(now())

  building Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  @@index([tenantId, userId, readAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────
// Building Core v1 — first-building-first, multi-building-ready
// All rows carry tenantId + buildingId. Each concern lives in its
// own table instead of a giant JSON blob on `buildings`.
// ─────────────────────────────────────────────────────────────

model BuildingFloor {
  id           String   @id @default(uuid())
  tenantId     String
  buildingId   String
  floorCode    String
  floorNumber  Int
  floorType    String
  label        String?
  isActive     Boolean  @default(true)
  grossAreaSqm Float?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  building         Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  units            BuildingUnit[]
  systems          BuildingSystem[]
  floorAssignments FloorAssignment[]

  @@unique([buildingId, floorCode])
  @@index([tenantId, buildingId, floorNumber])
  @@map("building_floors")
}

// INIT-004 Phase 1 — narrows "who covers floor X for role Y in building Z".
// Resolver chain (apps/api/src/modules/assignment) reads this in step 1
// when a CleaningRequest / Incident / ServiceRequest is created with a
// known floorId, before considering today's availability and team-wide
// fallbacks. UNIQUE keeps the same person from being double-counted on
// one floor for one role — we still allow many people per floor (just one
// row each) and we allow `primary` to mark the preferred coverer.
model FloorAssignment {
  id         String   @id @default(uuid())
  tenantId   String
  buildingId String
  floorId    String
  userId     String
  roleKey    String
  primary    Boolean  @default(false)
  createdAt  DateTime @default(now())
  createdBy  String?

  floor BuildingFloor @relation(fields: [floorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, floorId, userId, roleKey])
  @@index([buildingId, floorId, roleKey])
  @@index([userId])
  @@map("floor_assignments")
}

// INIT-004 Phase 1 — daily availability toggle. Resolver reads "is this
// user usable today?" before assigning. NULL row for (user, today) means
// "default — present" (no row needed for normal days). Manager only
// inserts when someone is absent. UNIQUE on (user, date) keeps history
// honest if the toggle flips during the day.
model UserAvailability {
  id       String   @id @default(uuid())
  tenantId String
  userId   String
  date     DateTime @db.Date
  status   String // present | absent | on_leave | sick
  reason   String?
  setBy    String?
  setAt    DateTime @default(now())

  @@unique([tenantId, userId, date])
  @@index([userId, date])
  @@index([tenantId, date, status])
  @@map("user_availability")
}

model BuildingUnit {
  id          String   @id @default(uuid())
  tenantId    String
  buildingId  String
  floorId     String
  unitCode    String
  unitType    String
  areaSqm     Float?
  layoutZone  String?
  isDivisible Boolean  @default(false)
  status      String   @default("vacant")
  notes       String?
  groupId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  building    Building                @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor       BuildingFloor           @relation(fields: [floorId], references: [id], onDelete: Cascade)
  group       BuildingUnitGroup?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  occupancies BuildingUnitOccupancy[]
  contracts   BuildingContract[]

  @@unique([buildingId, unitCode])
  @@index([tenantId, buildingId, floorId])
  @@index([groupId])
  @@map("building_units")
}

// SSOT §P11 — combined office: multiple BuildingUnits treated as one
// logically rented space by the same occupant company. Used when a single
// company rents 2+ adjacent/non-adjacent units and wants unified reporting
// (floor plan, contracts, tasks, evidence).
model BuildingUnitGroup {
  id                String   @id @default(uuid())
  tenantId          String
  buildingId        String
  groupCode         String
  name              String
  occupantCompanyId String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  building        Building                 @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  occupantCompany BuildingOccupantCompany? @relation(fields: [occupantCompanyId], references: [id], onDelete: SetNull)
  units           BuildingUnit[]

  @@unique([buildingId, groupCode])
  @@index([tenantId, buildingId])
  @@index([occupantCompanyId])
  @@map("building_unit_groups")
}

// Canonical physical location within a building. One row per room/space.
// Used by every module that needs to reference a space (cleaning, PPM,
// security, incidents, QR). Leasable offices live as BuildingUnit rows;
// non-leasable common areas (restrooms, corridors, lobbies, mechanical
// rooms) live as BuildingLocation rows. The `GET /v1/buildings/:id/locations`
// endpoint returns BOTH as a unified list.
model BuildingLocation {
  id           String   @id @default(uuid())
  tenantId     String
  buildingId   String
  floorId      String
  code         String // unique within the building
  name         String
  locationType String // restroom | corridor | lobby | shared_area | mechanical_room | storage | office | meeting_room | kitchen | custom
  areaSqm      Float?
  isLeasable   Boolean  @default(false)
  unitId       String?  @unique // optional back-link to BuildingUnit if this location IS a leasable unit
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([buildingId, code])
  @@index([tenantId, buildingId, floorId])
  @@index([locationType])
  @@map("building_locations")
}

model BuildingVerticalTransport {
  id              String   @id @default(uuid())
  tenantId        String
  buildingId      String
  code            String
  transportType   String
  servesFromFloor Int
  servesToFloor   Int
  quantity        Int      @default(1)
  status          String   @default("active")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([buildingId, code])
  @@index([tenantId, buildingId, transportType])
  @@map("building_vertical_transport")
}

model BuildingSystem {
  id             String   @id @default(uuid())
  tenantId       String
  buildingId     String
  systemCategory String
  systemCode     String
  name           String
  locationType   String?
  floorId        String?
  quantity       Int?
  status         String   @default("active")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  building Building       @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor    BuildingFloor? @relation(fields: [floorId], references: [id], onDelete: SetNull)

  @@unique([buildingId, systemCode])
  @@index([tenantId, buildingId, systemCategory])
  @@map("building_systems")
}

model BuildingOccupantCompany {
  id          String   @id @default(uuid())
  tenantId    String
  buildingId  String
  companyName String
  companyType String?
  contactName String?
  phone       String?
  email       String?
  notes       String?
  // INIT-007 Phase 4 — TENANT_COMPANY_ADMIN link. When populated the
  // referenced User gets RBAC grant TENANT_COMPANY_ADMIN with scope
  // tenantCompanyId = this.id. Nullable so companies without a designated
  // admin still work (requests stay at reception / manager visibility).
  adminUserId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  building    Building                 @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  occupancies BuildingUnitOccupancy[]
  contracts   BuildingContract[]
  unitGroups  BuildingUnitGroup[]
  settings    OccupantCompanySettings?

  @@index([tenantId, buildingId])
  @@index([adminUserId])
  @@map("building_occupant_companies")
}

// SSOT §P11 — per-tenant (occupant company) preferences and service
// entitlements. 1:1 with BuildingOccupantCompany. Stores values that differ
// between tenants of the same building: cleaning frequency, insurance,
// notification channels, allocations they purchased (parking count, storage).
model OccupantCompanySettings {
  id                   String    @id @default(uuid())
  tenantId             String
  occupantCompanyId    String    @unique
  // Cleaning
  cleaningFrequency    String    @default("daily") // daily | weekdays | weekly | custom
  cleaningSlaHours     Int       @default(24)
  cleaningZone         String? // free-text zone label inside the shared scheme
  // Allocations (what they paid for)
  parkingCount         Int       @default(0)
  storageCount         Int       @default(0)
  // Compliance / access
  insuranceRequired    Boolean   @default(true)
  insuranceExpiresAt   DateTime?
  accessCardCount      Int       @default(0)
  allowsAfterHours     Boolean   @default(false)
  // Billing / comms
  billingEmail         String?
  preferredLanguage    String    @default("en")
  notificationChannels String[]  @default([]) // ['email', 'sms', 'inapp']
  // Notes & custom
  notes                String?
  customFields         Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  occupantCompany BuildingOccupantCompany @relation(fields: [occupantCompanyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("occupant_company_settings")
}

model BuildingUnitOccupancy {
  id                String    @id @default(uuid())
  tenantId          String
  buildingId        String
  unitId            String
  occupantCompanyId String
  startDate         DateTime?
  endDate           DateTime?
  occupancyStatus   String    @default("active")
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  building        Building                @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit            BuildingUnit            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  occupantCompany BuildingOccupantCompany @relation(fields: [occupantCompanyId], references: [id], onDelete: Cascade)

  @@index([tenantId, buildingId, unitId])
  @@index([occupantCompanyId])
  @@map("building_unit_occupancies")
}

model BuildingContract {
  id                String    @id @default(uuid())
  tenantId          String
  buildingId        String
  // Counterparty is EITHER an occupant company (lease contracts) OR an
  // organization-as-vendor (service contracts). Exactly one must be set.
  // Previously occupantCompanyId was required and PPM seed polluted the
  // occupant table with vendor rows — now vendor contracts use vendorOrgId.
  occupantCompanyId String?
  vendorOrgId       String?
  unitId            String?
  contractType      String
  contractNumber    String?
  startDate         DateTime?
  endDate           DateTime?
  status            String    @default("draft")
  amount            Float?
  currency          String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // SSOT §P13 — escalation policy: { type: 'cpi'|'fixed_pct'|'stepped',
  // ratePct?: number, indexBase?: string, schedule?: [{ atMonth: number, ratePct: number }] }
  escalationPolicy    Json?
  paymentFrequency    String  @default("monthly") // monthly | quarterly | yearly
  noticePeriodDays    Int?
  insuranceDocumentId String?

  building        Building                 @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  occupantCompany BuildingOccupantCompany? @relation(fields: [occupantCompanyId], references: [id], onDelete: Cascade)
  vendorOrg       Organization?            @relation("BuildingContractVendor", fields: [vendorOrgId], references: [id], onDelete: SetNull)
  unit            BuildingUnit?            @relation(fields: [unitId], references: [id], onDelete: SetNull)
  allocations     LeaseAllocation[]

  @@index([tenantId, buildingId, contractType])
  @@index([occupantCompanyId])
  @@index([vendorOrgId])
  @@map("building_contracts")
}

// SSOT §P13 — single contract can cover multiple billable items: extra units,
// parking spots, storage. Replaces hard-coded one-unit assumption.
model LeaseAllocation {
  id            String   @id @default(uuid())
  tenantId      String
  contractId    String
  targetType    String // unit | parking_spot | storage_unit
  targetId      String
  share         Float    @default(1.0) // 0..1 portion of monthly amount apportioned here
  monthlyAmount Float    @default(0)
  currency      String   @default("ILS")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contract BuildingContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, targetType, targetId])
  @@index([tenantId, contractId])
  @@index([tenantId, targetType, targetId])
  @@map("lease_allocations")
}

// SSOT §P11 — links a platform User to an occupying company so the user can
// open the tenant self-service view scoped to their company.
model TenantRepresentative {
  id                String   @id @default(uuid())
  tenantId          String
  buildingId        String
  occupantCompanyId String
  userId            String
  role              String   @default("primary_contact") // primary_contact | building_committee | finance_contact
  status            String   @default("active") // active | revoked
  invitedByUserId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([occupantCompanyId, userId])
  @@index([tenantId, userId])
  @@index([tenantId, buildingId])
  @@map("tenant_representatives")
}

// Transactional outbox (SSOT §P16)
model OutboxEvent {
  id              String    @id @default(uuid())
  tenantId        String
  buildingId      String?
  specversion     String    @default("1.0")
  type            String
  source          String
  subject         String?
  datacontenttype String    @default("application/json")
  time            DateTime  @default(now())
  data            Json
  status          String    @default("pending")
  attempts        Int       @default(0)
  lastAttemptAt   DateTime?
  lastError       String?
  deliveredAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([tenantId, status, createdAt])
  @@index([type])
  @@map("outbox_events")
}

model WebhookSubscription {
  id              String   @id @default(uuid())
  tenantId        String
  url             String
  eventTypes      String[] @default([])
  sharedSecret    String
  isActive        Boolean  @default(true)
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, isActive])
  @@map("webhook_subscriptions")
}

model InboundWebhookSource {
  id              String   @id @default(uuid())
  tenantId        String
  channel         String
  sharedSecret    String
  signatureHeader String   @default("x-signature")
  signatureAlgo   String   @default("sha256")
  isActive        Boolean  @default(true)
  createdByUserId String
  createdAt       DateTime @default(now())

  @@unique([tenantId, channel])
  @@map("inbound_webhook_sources")
}

model InboundWebhookEvent {
  id          String   @id @default(uuid())
  tenantId    String
  channel     String
  receivedAt  DateTime @default(now())
  signatureOk Boolean
  rawHeaders  Json
  rawBody     String
  action      String   @default("logged")
  notes       String?

  @@index([tenantId, channel, receivedAt])
  @@map("inbound_webhook_events")
}

model PersonalDataCategory {
  id            String   @id @default(uuid())
  tenantId      String
  key           String
  name          String
  lawfulBasis   String
  retentionDays Int?
  location      String
  processors    String[] @default([])
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, key])
  @@map("personal_data_categories")
}

model DsarRequest {
  id                String    @id @default(uuid())
  tenantId          String
  subjectUserId     String?
  subjectEmail      String
  kind              String
  status            String    @default("received")
  requestedAt       DateTime  @default(now())
  verifiedAt        DateTime?
  completedAt       DateTime?
  fulfilmentSummary Json?
  assignedToUserId  String?
  rejectionReason   String?

  @@index([tenantId, status])
  @@index([subjectEmail])
  @@map("dsar_requests")
}

// SSOT §P19 — DPA templates + subprocessor registry
model SubprocessorRegistry {
  id               String    @id @default(uuid())
  tenantId         String
  name             String
  legalEntity      String?
  countryCode      String?
  category         String // hosting | email | sms | storage | analytics | accounting | other
  websiteUrl       String?
  dpoEmail         String?
  region           String? // e.g. "EU", "Israel", "US-East"
  dataCategories   String[]  @default([]) // PersonalDataCategory.key list this subprocessor touches
  notes            String?
  approvedAt       DateTime?
  approvedByUserId String?
  status           String    @default("active") // active | suspended | retired
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, status])
  @@map("subprocessor_registry")
}

model DpaTemplate {
  id              String    @id @default(uuid())
  tenantId        String
  key             String // controller_to_processor | joint_controller | tom_addendum
  name            String
  jurisdiction    String    @default("EU")
  version         Int       @default(1)
  isActive        Boolean   @default(true)
  bodyMarkdown    String
  placeholders    String[]  @default([])
  retentionYears  Int?
  effectiveFrom   DateTime  @default(now())
  effectiveUntil  DateTime?
  supersedesId    String?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, key, jurisdiction, version])
  @@index([tenantId, isActive])
  @@map("dpa_templates")
}

// ── OIDC / SAML SSO (SSOT §P2) ──────────────────────────────────────
// Per-tenant registration of an upstream identity provider.
model IdentityProvider {
  id                    String   @id @default(uuid())
  tenantId              String
  key                   String // "google" | "microsoft" | "okta-acme" | custom
  displayName           String
  protocol              String   @default("oidc") // oidc | saml
  // OIDC fields
  issuerUrl             String? // e.g. https://accounts.google.com
  clientId              String?
  clientSecret          String? // encrypt at rest in production
  scopes                String[] @default(["openid", "email", "profile"])
  authorizationEndpoint String?
  tokenEndpoint         String?
  userinfoEndpoint      String?
  jwksUri               String?
  // SAML fields (metadata URL or inline entity descriptor)
  samlMetadataUrl       String?
  samlEntityId          String?
  // Mapping
  emailClaim            String   @default("email")
  nameClaim             String   @default("name")
  groupClaim            String? // if set, groups → role assignment
  // Status
  isActive              Boolean  @default(true)
  createdByUserId       String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, isActive])
  @@map("identity_providers")
}

// Federated identity link — maps an upstream subject (sub) to a local user.
model FederatedIdentity {
  id          String    @id @default(uuid())
  userId      String
  providerId  String
  subject     String // "sub" claim from upstream
  email       String?
  displayName String?
  rawClaims   Json?
  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?

  @@unique([providerId, subject])
  @@index([userId])
  @@map("federated_identities")
}

// Ephemeral state for the OIDC authorize → callback handshake.
// Persists PKCE code_verifier + nonce + return-to URL between the
// /sso/login redirect and /sso/callback consumption. TTL 10 minutes.
model OidcLoginState {
  id           String   @id @default(uuid())
  tenantId     String
  providerId   String
  state        String   @unique
  nonce        String
  codeVerifier String
  redirectTo   String
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([expiresAt])
  @@map("oidc_login_states")
}

// ── SCIM 2.0 (SSOT §P2) ─────────────────────────────────────────────
// Bearer token exchanged with an enterprise IdP for /scim/v2/Users.
model ScimToken {
  id              String    @id @default(uuid())
  tenantId        String
  tokenHash       String    @unique
  label           String
  isActive        Boolean   @default(true)
  createdByUserId String
  createdAt       DateTime  @default(now())
  lastUsedAt      DateTime?
  revokedAt       DateTime?

  @@index([tenantId, isActive])
  @@map("scim_tokens")
}

// ── Signed URLs for document reads (SSOT §P18) ──────────────────────
model SignedUrl {
  id              String    @id @default(uuid())
  tenantId        String
  documentId      String
  token           String    @unique
  expiresAt       DateTime
  usesLeft        Int       @default(1)
  createdByUserId String
  createdAt       DateTime  @default(now())
  usedAt          DateTime?

  @@index([tenantId, documentId])
  @@index([expiresAt])
  @@map("signed_urls")
}

// ═══════════════════════════════════════════════════════════════════
// Cleaning module (bounded context): contractors, staff hierarchy, zones,
// QR points, cleaning requests + lifecycle audit. Intentionally separated
// from PPM/maintenance — a cleaning request is NOT a TaskInstance.
// ═══════════════════════════════════════════════════════════════════
model CleaningContractor {
  id                  String   @id @default(uuid())
  tenantId            String
  buildingId          String
  // INIT-007 Phase 6 — link to the universal ContractorCompany. NULL on
  // legacy rows; new rows (created via /v1/contractor-companies) get
  // populated automatically. Lets the policy engine treat cleaning +
  // technical + security contractors with one scope dimension.
  contractorCompanyId String?
  name                String
  legalName           String?
  phone               String?
  email               String?
  isActive            Boolean  @default(true)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([buildingId, name])
  @@index([tenantId, buildingId, isActive])
  @@index([contractorCompanyId])
  @@map("cleaning_contractors")
}

// INIT-007 Phase 6 — universal ContractorCompany.
//
// Cleaning has had its own CleaningContractor model since INIT-001;
// technical + security work has been routed through Organization (with
// type="vendor") via WorkOrder.vendorOrgId / TaskInstance.performerOrgId.
// That parallel modelling makes scope hard: a CONTRACTOR_MANAGER cannot
// say "I manage company X across all domains". This model unifies them
// — every domain-specific contractor (CleaningContractor, future
// TechnicalContractor, SecurityContractor) carries a contractorCompanyId
// pointing here, and TaskInstance + WorkOrder gain the same FK so role
// scope = { contractorCompanyId } narrows everything.
model ContractorCompany {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  legalName String?
  domain    String // cleaning | technical | security | generic
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, domain, isActive])
  @@map("contractor_companies")
}

model CleaningRole {
  id           String   @id @default(uuid())
  tenantId     String
  contractorId String
  code         String // boss | manager | supervisor | cleaner | dispatcher
  name         String
  createdAt    DateTime @default(now())

  @@unique([contractorId, code])
  @@index([tenantId, contractorId])
  @@map("cleaning_roles")
}

model CleaningStaff {
  id           String   @id @default(uuid())
  tenantId     String
  contractorId String
  userId       String?
  fullName     String
  phone        String?
  email        String?
  roleId       String
  managerId    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, contractorId, isActive])
  @@index([userId])
  @@index([managerId])
  @@map("cleaning_staff")
}

model CleaningZone {
  id                String   @id @default(uuid())
  tenantId          String
  buildingId        String
  floorId           String?
  locationId        String?
  name              String
  code              String
  zoneType          String // floor | wc | office | lobby | corridor | shared_area | custom
  contractorId      String?
  supervisorStaffId String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([buildingId, code])
  @@index([tenantId, buildingId, contractorId])
  @@index([zoneType])
  @@map("cleaning_zones")
}

model CleaningQrPoint {
  id            String    @id @default(uuid())
  tenantId      String
  buildingId    String
  zoneId        String
  locationId    String?
  code          String    @unique // short, random, unguessable public code
  label         String
  publicUrl     String
  isActive      Boolean   @default(true)
  lastScannedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, buildingId, isActive])
  @@index([zoneId])
  @@map("cleaning_qr_points")
}

model CleaningRequest {
  id                  String    @id @default(uuid())
  tenantId            String
  buildingId          String
  zoneId              String
  qrPointId           String?
  createdByUserId     String?
  createdByGuestName  String?
  createdByGuestPhone String?
  source              String // dashboard | qr | admin | dispatcher
  category            String // regular_cleaning | urgent_cleaning | spill | restroom_issue | trash_overflow | other
  title               String
  description         String?
  priority            String    @default("normal") // low | normal | high | urgent
  status              String    @default("new") // new | assigned | in_progress | done | rejected | cancelled
  contractorId        String?
  assignedStaffId     String?
  requestedAt         DateTime  @default(now())
  assignedAt          DateTime?
  startedAt           DateTime?
  resolvedAt          DateTime?
  dueAt               DateTime?
  closedByUserId      String?
  // INIT-004 — auto-assignment context. Cleaning already has
  // assignedStaffId pointing at CleaningStaff (cleaning-specific
  // hierarchy). assignedUserId points at the platform User who got
  // routed via the resolver — null when the resolver chose a
  // CleaningStaff member who is not yet bound to a User account.
  assignedUserId      String?
  assignmentSource    String?
  assignmentReason    String?
  floorId             String?
  tenantCompanyId     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([tenantId, buildingId, status])
  @@index([contractorId, status])
  @@index([assignedStaffId, status])
  @@index([zoneId])
  @@index([dueAt])
  @@index([assignedUserId])
  @@index([tenantCompanyId])
  @@map("cleaning_requests")
}

model CleaningRequestComment {
  id            String   @id @default(uuid())
  tenantId      String
  requestId     String
  authorUserId  String?
  authorStaffId String?
  body          String
  isInternal    Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([requestId, createdAt])
  @@index([tenantId])
  @@map("cleaning_request_comments")
}

model CleaningRequestAttachment {
  id                String   @id @default(uuid())
  tenantId          String
  requestId         String
  fileUrl           String
  fileType          String
  uploadedByUserId  String?
  uploadedByStaffId String?
  createdAt         DateTime @default(now())

  @@index([requestId])
  @@index([tenantId])
  @@map("cleaning_request_attachments")
}

model CleaningRequestHistory {
  id          String   @id @default(uuid())
  tenantId    String
  requestId   String
  action      String
  actorType   String // user | staff | system | guest
  actorId     String?
  payloadJson Json?
  createdAt   DateTime @default(now())

  @@index([requestId, createdAt])
  @@index([tenantId])
  @@map("cleaning_request_history")
}

model UserMfa {
  id         String    @id @default(uuid())
  userId     String    @unique
  secret     String
  algorithm  String    @default("SHA1")
  digits     Int       @default(6)
  period     Int       @default(30)
  enabledAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("user_mfa")
}

model SeedRun {
  id          String    @id @default(uuid())
  tenantId    String?
  seedName    String
  seedVersion String
  status      String
  checksum    String
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  createdBy   String    @default("seed:test-building")
  errorText   String?

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([seedName, seedVersion])
  @@map("seed_runs")
}

/// Registered push-notification device. One row per (user, expo push token).
/// Tenant-scoped so admins can revoke devices for a specific workspace without
/// touching the user's other sessions.
model Device {
  id            String   @id @default(uuid())
  tenantId      String
  userId        String
  platform      String // 'ios' | 'android' | 'web'
  expoPushToken String   @unique
  osVersion     String?
  appVersion    String?
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([userId])
  @@map("devices")
}
