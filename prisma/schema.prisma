// Reusable document templates (sketch forms, printable samples, reference
// packs). Used by PPM completion flows as the authoritative evidence template
// that the performer must fill out or attach. Templates live per-tenant and
// can optionally be scoped to a specific building.
//
//   - kind=sketch_form   : body_markdown holds a fillable markdown form
//                          (question prompts, numbered checkpoints, tables).
//                          Completion produces a Document instance rendered
//                          from the filled template.
//   - kind=printable     : sampleDocumentId points to an uploaded sample
//                          (e.g. the blank form the authority expects;
//                          operator prints it, fills by hand, scans back).
//   - kind=reference     : informational — no fill-in, just attached for
//                          guidance (SOP, checklist PDF).
model DocumentTemplate {
  id                     String   @id @default(uuid())
  tenantId               String
  buildingId             String? // optional scope; null = tenant-wide
  key                    String // stable identifier within (tenantId, key)
  name                   String
  description            String?
  kind                   String // sketch_form | printable | reference
  documentTypeKey        String? // link to DocumentType taxonomy
  bodyMarkdown           String? // sketch_form body
  sampleDocumentId       String? // printable/reference sample Document
  requiresPhoto          Boolean  @default(false)
  requiresDigitalSignoff Boolean  @default(false)
  retentionYears         Int?
  isActive               Boolean  @default(true)
  createdByUserId        String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, buildingId, isActive])
  @@index([documentTypeKey])
  @@map("document_templates")
}

// ── Rounds (inspection walks / checklists) ──────────────────────────
// A "Round" is a named sequence of waypoints a person walks through,
// e.g. "Morning fire-safety walk" or "Weekly restroom check". Each
// waypoint references a canonical BuildingLocation and a
// DocumentTemplate (the checklist to fill at that spot).
// Rounds are scheduled (optional RRULE) and produce RoundInstance rows
// when executed.
model Round {
  id               String   @id @default(uuid())
  tenantId         String
  buildingId       String
  name             String
  description      String?
  recurrenceRule   String? // optional RRULE; null = ad-hoc
  assignedRole     String? // default role that runs the round
  estimatedMinutes Int?
  isActive         Boolean  @default(true)
  createdByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  waypoints RoundWaypoint[]

  @@index([tenantId, buildingId, isActive])
  @@map("rounds")
}

model RoundWaypoint {
  id                      String   @id @default(uuid())
  tenantId                String
  roundId                 String
  orderNo                 Int
  locationId              String? // BuildingLocation.id (canonical)
  unitId                  String? // OR BuildingUnit.id
  legacyZoneId            String? // OR legacy CleaningZone.id
  label                   String // display name for this step
  documentTemplateId      String? // checklist to complete here
  requiresPhoto           Boolean  @default(false)
  requiresSignature       Boolean  @default(false)
  expectedDurationMinutes Int?
  notes                   String?
  createdAt               DateTime @default(now())

  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([roundId, orderNo])
  @@index([tenantId, roundId])
  @@index([documentTemplateId])
  @@map("round_waypoints")
}

// Execution of a Round by a user. Each answered waypoint becomes a row
